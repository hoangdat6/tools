# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# S3 Bucket Configuration
BUCKET_NAME=my-cic-parquet-data
S3_PREFIX=cic_parquet

# Local Data Path
LOCAL_DATA_PATH=./cicflow_parquet

# Upload Settings
UPLOAD_WORKERS=10
MAX_RETRIES=3

# Bucket Features (true/false)
ENABLE_VERSIONING=false
ENABLE_ENCRYPTION=true
ENABLE_LIFECYCLE_POLICY=false

# Lifecycle Policy (days)
# Only applies if ENABLE_LIFECYCLE_POLICY=true
TRANSITION_TO_IA_DAYS=30
TRANSITION_TO_GLACIER_DAYS=90
EXPIRATION_DAYS=365
