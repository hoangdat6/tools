# Core execution
export TARGET_USER=ubuntu
export SETUP_RETRY_COUNT=3
export SETUP_MIN_DISK_MB=2048
# export INFRA_ROOT=/home/ubuntu/infra
# export SETUP_LOG_FILE=/home/ubuntu/infra/setup-server-tool/state/setup.log
# export SETUP_MANIFEST_FILE=/home/ubuntu/infra/setup-server-tool/state/manifest.tsv

# Pinned tools
export AWS_CLI_VERSION=2.36.4
export DOCKER_COMPOSE_VERSION=v5.1.4
export NVM_VERSION=v0.40.6
export NODE_VERSIONS="20 22 24"
export NODE_DEFAULT_VERSION=22

# Web stack
export NGINX_MODE=apt
export NGINX_IMAGE=nginx:1.28.0-alpine
export NPM_IMAGE=jc21/nginx-proxy-manager:2.15.0
# export NPM_ADMIN_BIND=0.0.0.0
export NPM_ADMIN_PORT=81

# Native Nginx certificate issuance
# export CERTBOT_DOMAINS="example.com www.example.com"
# export CERTBOT_EMAIL=admin@example.com
# export CERTBOT_MODE=nginx

# Baseline and security
export SERVER_TIMEZONE=UTC
export BASELINE_SWAP_SIZE_GB=0
# export SERVER_HOSTNAME=app-01
# export ADMIN_USER=deploy
# export ADMIN_SSH_PUBLIC_KEY="ssh-ed25519 AAAA..."
export SSH_PORT=22
export SSH_DISABLE_PASSWORD_AUTH=true
export SECURITY_ENABLE_FIREWALL=true
